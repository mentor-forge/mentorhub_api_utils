[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
flask = "*"
pymongo = "*"
prometheus-flask-exporter = "*"
pyjwt = "*"

[dev-packages]
pytest = "*"
black = "*"
setuptools = "*"
build = "*"
twine = "*"
requests = "*"

[scripts]
build = "sh scripts/check-merged && python -m build"
dev = "sh scripts/check-merged && sh -c 'JWT_SECRET=local-dev-jwt-secret-fixed PYTHONPATH=. python api_utils/server.py'"
test = "sh scripts/check-merged && sh -c 'PYTHONPATH=. pytest tests/ -v -m \"not e2e\"'"
e2e = "sh scripts/check-merged && sh -c 'PYTHONPATH=. pytest tests/ -m e2e -v'"
lint = "sh scripts/check-merged && black --check api_utils tests"
format = "sh scripts/check-merged && black api_utils tests"
db = "{{info.developer_cli}} up mongodb"
build-publish = "sh -c 'scripts/check-merged && pipenv install --dev && pipenv run build'"
build-package = "sh -c 'scripts/check-merged && pipenv install --dev && pipenv run build'"
publish-package = "sh -c 'echo publish-package: no-op for api_utils'"
delete-package = "sh -c 'echo delete-package: no-op for api_utils'"

[requires]
python_version = "3.12"